#!/bin/sh
#
# Russignol signer init script for DEV build (SysV init)
#
# IMPORTANT: This file is for the DEV build only.
# The HARDENED build uses a monolithic /init script instead:
#   - rootfs-overlay-hardened/init
# If you change partition layout, paths, or startup logic here,
# you MUST also update the hardened init script to match.
#
# NOTE: The signer handles its own first-boot detection and setup.
# This script just mounts partitions and starts the signer as russignol user.
#

PID_FILE="/var/run/russignol.pid"
USER="russignol"
COMMAND="/bin/russignol-signer"
export RUST_LOG=info

# Signer exits with this code to request a clean reboot from the init
# supervisor (used to land each PIN-blob migration step on a fresh boot).
# Must stay in sync with the matching constants in
# `rpi-signer/src/app.rs` (`EXIT_CODE_REBOOT`) and
# `rpi-signer/buildroot-external/rootfs-overlay-hardened/init`.
EXIT_CODE_REBOOT=42

# Partition layout (created at first boot by signer):
# - p3 (keys): Holds encrypted keys, becomes RO after setup
# - p4 (data): Holds watermarks and logs
KEYS_PART="/dev/mmcblk0p3"
KEYS_MOUNT="/keys"
DATA_PART="/dev/mmcblk0p4"
DATA_MOUNT="/data"
SETUP_MARKER="/keys/.setup_complete"
# Boot partition (p1, vfat): a host doctor without f2fs support stages
# watermark-config.json here for the device to consume on the next boot; the
# host also writes flash-manifest.json here at flash time.
BOOT_PART="/dev/mmcblk0p1"
BOOT_PROBE_MOUNT="/tmp/boot-config-probe"
WATERMARK_CONFIG="watermark-config.json"
FLASH_MANIFEST_FILE="flash-manifest.json"
# inline_data/inline_dentry: store small files in inode (reduces write amplification)
F2FS_OPTS="rw,inline_data,inline_dentry,fsync_mode=strict,atgc,gc_merge,alloc_mode=reuse,background_gc=off,errors=remount-ro"

# Check if partition exists in kernel (created at first boot)
partition_exists() {
    [ -e "/sys/block/mmcblk0/mmcblk0p$1" ]
}

# Check if a partition is mounted
is_mounted() {
    grep -q "^$1 " /proc/mounts
}

# Returns success when the keys partition needs to stay rw so the signer can
# run the v1->v2 PIN-blob migration. Presence of the v1-named blob is the
# whole signal: it means either staging or verify-and-promote is pending.
needs_migration() {
    [ -f "${KEYS_MOUNT}/secret_keys.enc" ]
}

# Returns success when a watermark-config.json is staged on the vfat boot
# partition. Probes with a throwaway read-only mount so the keys-mount and
# daemon-start decisions below can keep /keys rw and run the signer as root,
# letting it write chain_info.json and remount ro before demoting in-process.
config_pending() {
    mkdir -p "${BOOT_PROBE_MOUNT}"
    mount -t vfat -o ro "${BOOT_PART}" "${BOOT_PROBE_MOUNT}" 2>/dev/null || return 1
    pending=1
    [ -f "${BOOT_PROBE_MOUNT}/${WATERMARK_CONFIG}" ] && pending=0
    umount "${BOOT_PROBE_MOUNT}" 2>/dev/null
    rmdir "${BOOT_PROBE_MOUNT}" 2>/dev/null
    return "$pending"
}

# Reads the host-written flash-manifest.json off p1 (read-only) into
# FLASH_MANIFEST, so the signer can show it on the Image screen. Empty on older
# cards with no manifest. The env-var name is a cross-language contract with the
# signer (rpi-signer/src/constants.rs FLASH_MANIFEST_ENV), like EXIT_CODE_REBOOT.
read_flash_manifest() {
    FLASH_MANIFEST=""
    mkdir -p "${BOOT_PROBE_MOUNT}"
    mount -t vfat -o ro "${BOOT_PART}" "${BOOT_PROBE_MOUNT}" 2>/dev/null || return 0
    [ -f "${BOOT_PROBE_MOUNT}/${FLASH_MANIFEST_FILE}" ] && FLASH_MANIFEST=$(cat "${BOOT_PROBE_MOUNT}/${FLASH_MANIFEST_FILE}")
    umount "${BOOT_PROBE_MOUNT}" 2>/dev/null
    rmdir "${BOOT_PROBE_MOUNT}" 2>/dev/null
}

mount_keys_partition() {
    # Check if p3 exists - if not, first boot hasn't created it yet
    if ! partition_exists 3; then
        echo "Keys partition (p3) not found - will be created by signer"
        return 0
    fi

    mkdir -p "${KEYS_MOUNT}"
    if ! is_mounted "${KEYS_PART}"; then
        # Mount read-write first to check for setup marker
        if mount -t f2fs -o rw "${KEYS_PART}" "${KEYS_MOUNT}" 2>/dev/null; then
            if [ -f "${SETUP_MARKER}" ]; then
                if needs_migration; then
                    echo "Keys partition kept rw for PIN migration"
                elif [ "$CONFIG_PENDING" = 1 ]; then
                    echo "Keys partition kept rw for watermark config recovery"
                else
                    # After setup: remount read-only for security
                    mount -o remount,ro "${KEYS_MOUNT}"
                fi
            fi
            # First boot: leave mounted read-write for key generation
        fi
    fi
}

mount_data_partition() {
    # Check if p4 exists - if not, first boot hasn't created it yet
    if ! partition_exists 4; then
        echo "Data partition (p4) not found - will be created by signer"
        return 0
    fi

    mkdir -p "${DATA_MOUNT}"
    if ! is_mounted "${DATA_PART}"; then
        if ! mount -t f2fs -o "${F2FS_OPTS}" "${DATA_PART}" "${DATA_MOUNT}" 2>/dev/null; then
            echo "ERROR: Failed to mount data partition (${DATA_PART})"
        fi
    fi
}

case "$1" in
    start)
        # Disable activity LED (~1mA / 5mW saving)
        echo 0 >/sys/class/leds/ACT/brightness 2>/dev/null

        echo "Starting Russignol"

        # Probe once for a staged boot-partition watermark config; the keys
        # mount and daemon-start decisions below both consult the result.
        if config_pending; then
            CONFIG_PENDING=1
        else
            CONFIG_PENDING=0
        fi

        # Read the flash manifest off p1 and export it for the signer's Image
        # screen. Inherited by the signer that start-stop-daemon launches below.
        read_flash_manifest
        export RUSSIGNOL_FLASH_MANIFEST="$FLASH_MANIFEST"

        # Mount partitions (if they exist)
        mount_keys_partition
        mount_data_partition

        # First boot (no partitions): run as root for storage setup
        #   - Signer will drop privileges to russignol after storage completes
        # After setup: run as unprivileged russignol user
        # Grant russignol write access to CPU freq control (sysfs resets to root each boot)
        chown russignol /sys/devices/system/cpu/cpufreq/policy0/scaling_setspeed 2>/dev/null
        chown russignol /sys/class/leds/ACT/brightness 2>/dev/null

        if ! partition_exists 3 || ! partition_exists 4; then
            echo "First boot detected - running as root for storage setup"
            echo "Signer will drop privileges after partition creation"
            if ! start-stop-daemon --start --make-pidfile --pidfile "$PID_FILE" \
                --chdir /home/russignol \
                --background --startas /bin/sh -- -c \
                "$COMMAND; ec=\$?; [ \$ec = $EXIT_CODE_REBOOT ] && reboot -f; exit \$ec"; then
                echo "Failed to start Russignol" >&2
                exit 1
            fi
        else
            mkdir -p /data/logs
            chown "$USER" /data/logs
            # Migration boots run the wrapper as root, which leaves
            # panic.log and signer.log owned root:root. The next normal
            # boot starts the wrapper via --chuid russignol, and its
            # `2>>panic.log` redirect would then fail with EACCES before
            # $COMMAND runs. Reclaim ownership unconditionally.
            chown "$USER" /data/logs/*.log 2>/dev/null
            # Truncate panic log if it exceeds 1MB
            if [ -f /data/logs/panic.log ] && [ "$(wc -c </data/logs/panic.log)" -gt 1048576 ]; then
                : >/data/logs/panic.log
            fi
            # Migration and watermark-config-recovery boots both run as root so
            # the signer can write /keys (promote the v2 blob, or write
            # chain_info.json) and remount it ro before demoting in-process.
            if needs_migration || [ "$CONFIG_PENDING" = 1 ]; then
                echo "Privileged boot - running as root; signer demotes in-process"
                # Binary manages its own log file via RotatingWriter; init only captures panics
                if ! start-stop-daemon --start --make-pidfile --pidfile "$PID_FILE" \
                    --chdir /home/russignol \
                    --background --startas /bin/sh -- -c \
                    "$COMMAND >/dev/null 2>>/data/logs/panic.log; ec=\$?; if [ \$ec = $EXIT_CODE_REBOOT ]; then echo \"signer requested reboot at \$(date)\" >>/data/logs/panic.log; reboot -f; fi; exit \$ec"; then
                    echo "Failed to start Russignol" >&2
                    exit 1
                fi
            else
                echo "Normal boot - running as $USER"
                # Binary manages its own log file via RotatingWriter; init only captures panics
                if ! start-stop-daemon --start --make-pidfile --pidfile "$PID_FILE" \
                    --chuid "$USER" \
                    --chdir /home/russignol \
                    --background --startas /bin/sh -- -c \
                    "$COMMAND >/dev/null 2>>/data/logs/panic.log; ec=\$?; if [ \$ec = $EXIT_CODE_REBOOT ]; then echo \"signer requested reboot at \$(date)\" >>/data/logs/panic.log; reboot -f; fi; exit \$ec"; then
                    echo "Failed to start Russignol" >&2
                    exit 1
                fi
            fi
        fi
        ;;
    stop)
        echo "Stopping Russignol the Tezos Signer"
        # Match the signer by its executable, not a pidfile: start-stop-daemon
        # --background records the /bin/sh wrapper's pid, and busybox sh does not
        # forward SIGTERM to its child, so stopping by pidfile kills the wrapper
        # and leaves the signer orphaned holding the display GPIO.
        if ! start-stop-daemon --stop --oknodo --exec "$COMMAND" --retry 5; then
            echo "Failed to stop Russignol" >&2
            exit 1
        fi
        ;;
    restart)
        "$0" stop
        sleep 1
        "$0" start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
