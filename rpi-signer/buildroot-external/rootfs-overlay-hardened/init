#!/bin/sh
#
# Hardened Monolithic /init (PID 1)
# Platform: Raspberry Pi Zero 2W
# Function: Network Gadget, Hardware Init, Partition Setup, Process Supervision
#
# Partition Layout:
# - p3 (keys): Created at first boot, 64MB for encrypted keys (becomes RO after key gen)
# - p4 (data): Created at first boot, 64MB for watermarks and logs
#
# IMPORTANT: This file is for the HARDENED build only.
# The DEV build uses SysV init scripts instead:
#   - rootfs-overlay-dev/etc/init.d/S20russignol
#   - rootfs-overlay-dev/etc/fstab
# If you change partition layout, paths, or startup logic here,
# you MUST also update the dev init scripts to match.
#

# ==============================================================================
# DEBUG LOGGING
# ==============================================================================
# shellcheck disable=SC2034  # log target, referenced when the echo below is enabled
DEBUG_LOG="/var/log/init.log"
log_debug() {
    # echo "$1" >> "$DEBUG_LOG"
    :
}

# ==============================================================================
# 0. SIGNAL HANDLING
# ==============================================================================
init_signals() {
    # As PID 1 this CHLD trap makes busybox ash prone to intermittently deadlock
    # any pipeline (`cmd | cmd`); keep pipelines out of this process.
    trap ':' CHLD
}

# ==============================================================================
# 1. ESSENTIAL MOUNTS
# ==============================================================================
init_mounts() {
    export PATH=/sbin:/usr/sbin:/bin:/usr/bin
    mount -t proc proc /proc
    mount -t sysfs sysfs /sys
    mount -t devtmpfs devtmpfs /dev 2>/dev/null || mount -t tmpfs mdev /dev
    mkdir -p /dev/pts
    mount -t devpts devpts /dev/pts -o gid=5,mode=620,ptmxmode=0666
    mount -t tmpfs tmpfs /tmp -o mode=1777,nosuid,nodev
    mount -t tmpfs tmpfs /run -o mode=0755,nosuid,nodev
    mkdir -p /dev/shm
    mount -t tmpfs tmpfs /dev/shm -o mode=1777,nosuid,nodev
}

# ==============================================================================
# 2. DEVICE MANAGER
# ==============================================================================
init_mdev() {
    echo "/sbin/mdev" >/proc/sys/kernel/hotplug
    mdev -s
}

# ==============================================================================
# 3. SEED RNG
# ==============================================================================
init_rng() {
    if [ -r "/etc/default/seedrng" ]; then
        # shellcheck source=/dev/null
        . "/etc/default/seedrng"
    fi
    seedrng "${SEEDRNG_ARGS:-}" || true
}

# ==============================================================================
# 4. PARTITION SETUP
# ==============================================================================
# Keys partition (p3) - created at first boot by signer, holds encrypted keys
KEYS_PART="/dev/mmcblk0p3"
KEYS_MOUNT="/keys"

# Data partition (p4) - created at first boot by signer, holds watermarks/logs
DATA_PART="/dev/mmcblk0p4"
DATA_MOUNT="/data"

# Setup marker lives on keys partition (survives data partition corruption)
SETUP_MARKER="${KEYS_MOUNT}/.setup_complete"

R_USER="russignol"
# inline_data/inline_dentry: store small files in inode (reduces write amplification)
F2FS_OPTS="rw,inline_data,inline_dentry,fsync_mode=strict,atgc,gc_merge,alloc_mode=reuse,background_gc=off,errors=remount-ro"

# Check if partition exists in kernel (created at first boot)
partition_exists() {
    [ -e "/sys/block/mmcblk0/mmcblk0p$1" ]
}

# Returns success when the keys partition needs to stay rw so the signer can
# run the v1->v2 PIN-blob migration. Presence of the v1-named blob is the
# whole signal: it means either staging or verify-and-promote is pending.
needs_migration() {
    [ -f "${KEYS_MOUNT}/secret_keys.enc" ]
}

init_keys_partition() {
    log_debug "Setting up keys partition..."

    # Check if p3 exists - if not, first boot hasn't created it yet
    if ! partition_exists 3; then
        log_debug "Keys partition (p3) not found - will be created by signer"
        return 0
    fi

    # Create mount point
    mkdir -p "${KEYS_MOUNT}"

    # Mount read-write first to check for setup marker
    if mount -t f2fs -o rw "${KEYS_PART}" "${KEYS_MOUNT}" 2>/dev/null; then
        if [ -f "${SETUP_MARKER}" ]; then
            if needs_migration; then
                log_debug "Setup complete, keys partition kept rw for PIN migration"
            else
                # After setup: remount read-only for security
                mount -o remount,ro "${KEYS_MOUNT}"
                log_debug "Setup complete, keys partition remounted read-only"
            fi
        else
            # First boot: keep read-write for key generation
            log_debug "First boot, keys partition kept read-write"
        fi
    else
        log_debug "ERROR: Failed to mount keys partition"
    fi
}

init_data_partition() {
    log_debug "Setting up data partition..."

    # Check if p4 exists - if not, first boot hasn't created it yet
    if ! partition_exists 4; then
        log_debug "Data partition (p4) not found - will be created by signer"
        return 0
    fi

    # Create mount point
    mkdir -p "${DATA_MOUNT}"

    # Mount data partition. The signer shows a fatal DATA UNAVAILABLE screen
    # when /data is missing, so record a mount failure rather than hiding it.
    if mount -t f2fs -o "${F2FS_OPTS}" "${DATA_PART}" "${DATA_MOUNT}" 2>/dev/null; then
        log_debug "Data partition setup complete"
    else
        log_debug "ERROR: Failed to mount data partition (${DATA_PART})"
    fi
}

# ==============================================================================
# 5. USB MODULE LOADING
# ==============================================================================
USB_CONFIGFS="/sys/kernel/config"

# First UDC name, or empty. Globs sysfs instead of `ls | head` to stay pipe-free
# (see init_signals).
first_udc() {
    for u in /sys/class/udc/*; do
        [ -e "$u" ] && {
            printf '%s\n' "${u##*/}"
            return 0
        }
    done
    return 1
}

load_usb_modules() {
    # uname not available in hardened busybox, find module dir directly
    for MODULE_DIR in /lib/modules/*/; do break; done
    MODULE_DIR=${MODULE_DIR%/} # remove trailing slash
    GADGET_DIR="$MODULE_DIR/kernel/drivers/usb/gadget"
    USB_DIR="$MODULE_DIR/kernel/drivers/usb"

    log_debug "  MODULE_DIR=$MODULE_DIR"
    log_debug "  dir exists: $([ -d "$MODULE_DIR" ] && echo YES || echo NO)"

    # Skip if gadget framework already available (built-in case)
    if [ -d "$USB_CONFIGFS/usb_gadget" ] 2>/dev/null; then
        log_debug "  usb_gadget already exists (built-in)"
        return 0
    fi

    # Load configfs module first
    CONFIGFS_KO="$MODULE_DIR/kernel/fs/configfs/configfs.ko"
    log_debug "  configfs.ko exists: $([ -f "$CONFIGFS_KO" ] && echo YES || echo NO)"
    # Do not pipe insmod here: as PID 1 (SIGCHLD trap in init_signals) this
    # pipeline can intermittently deadlock in busybox ash, wedging USB bring-up.
    if [ -f "$CONFIGFS_KO" ]; then
        insmod "$CONFIGFS_KO"
        log_debug "  insmod configfs ret=$?"
    fi

    # Mount configfs BEFORE loading libcomposite
    log_debug "  configfs in mounts: $(grep -q configfs /proc/mounts && echo YES || echo NO)"
    if ! grep -q configfs /proc/mounts; then
        mount -t configfs none "$USB_CONFIGFS" 2>&1
        log_debug "  mount configfs ret=$?"
    fi
    log_debug "  configfs now mounted: $(grep -q configfs /proc/mounts && echo YES || echo NO)"

    # Load remaining modules
    for mod in \
        "$USB_DIR/common/usb-common.ko" \
        "$GADGET_DIR/udc/udc-core.ko" \
        "$USB_DIR/roles/roles.ko" \
        "$USB_DIR/phy/phy-generic.ko" \
        "$USB_DIR/dwc2/dwc2.ko" \
        "$GADGET_DIR/libcomposite.ko" \
        "$GADGET_DIR/function/u_ether.ko" \
        "$GADGET_DIR/function/usb_f_ecm.ko"; do
        if [ -f "$mod" ]; then
            insmod "$mod"
            log_debug "  insmod ${mod##*/} ret=$?"
        else
            log_debug "  MISSING: $mod"
        fi
    done

    # Wait for UDC
    log_debug "  Waiting for UDC..."
    for _ in $(seq 1 30); do
        [ -n "$(first_udc)" ] && break
        sleep 0.1
    done
    log_debug "  UDC contents: $(first_udc || echo EMPTY)"

    # Wait for usb_gadget
    log_debug "  Waiting for usb_gadget..."
    for _ in $(seq 1 20); do
        [ -d "$USB_CONFIGFS/usb_gadget" ] && {
            log_debug "  usb_gadget appeared"
            return 0
        }
        sleep 0.1
    done

    log_debug "  usb_gadget NOT found"
    return 1
}

# ==============================================================================
# 6. USB GADGET SETUP
# ==============================================================================
USB_GADGET="$USB_CONFIGFS/usb_gadget/g1"
USB_IFACE="usb0"

# Locally-administered MAC (02:...) from five byte-pairs of the hex CPU serial,
# starting at char offset $2 (0 = host side, 2 = device side). Pure parameter
# expansion, no `echo | sed` (see init_signals). Outputs nothing on a short
# serial so the callers' fallback MACs apply.
serial_to_mac() {
    rest=$1
    [ "$2" = 2 ] && rest=${rest#??}
    [ "${#rest}" -ge 10 ] || return 1
    mac=02
    i=0
    while [ "$i" -lt 5 ]; do
        pair=${rest%"${rest#??}"}
        mac="$mac:$pair"
        rest=${rest#??}
        i=$((i + 1))
    done
    printf '%s\n' "$mac"
}

# Body is a subshell: this cds into configfs, and the supervisor calls it
# repeatedly — the caller's cwd must never sit inside the tree a later call
# rm -rfs.
setup_gadget() (
    # Ensure ConfigFS is mounted
    if ! grep -q configfs /proc/mounts; then
        mount -t configfs none "$USB_CONFIGFS" 2>/dev/null
    fi

    # Cleanup previous
    if [ -d "$USB_GADGET" ]; then
        echo "" >"$USB_GADGET/UDC" 2>/dev/null || true
        rm -rf "$USB_GADGET"
    fi

    mkdir -p "$USB_GADGET"
    cd "$USB_GADGET" || return 1

    echo 0x1d6b >idVendor
    echo 0x0104 >idProduct
    echo 0x0100 >bcdDevice
    echo 0x0200 >bcdUSB

    # Deterministic identity from CPU serial (stable across reboots)
    USB_SERIAL=$(sed -n 's/^Serial[[:space:]]*:[[:space:]]*//p' /proc/cpuinfo)
    HOST_MAC=$(serial_to_mac "$USB_SERIAL" 0)
    DEV_MAC=$(serial_to_mac "$USB_SERIAL" 2)

    mkdir -p strings/0x409
    echo "${USB_SERIAL:-0123456789}" >strings/0x409/serialnumber
    echo "Russignol" >strings/0x409/manufacturer
    echo "Russignol Ethernet" >strings/0x409/product

    mkdir -p configs/c.1/strings/0x409
    echo "ECM Network" >configs/c.1/strings/0x409/configuration
    echo 500 >configs/c.1/MaxPower

    mkdir -p functions/ecm.usb0
    echo "${HOST_MAC:-02:00:00:00:00:01}" >functions/ecm.usb0/host_addr
    echo "${DEV_MAC:-02:00:00:00:00:02}" >functions/ecm.usb0/dev_addr

    ln -s functions/ecm.usb0 configs/c.1/

    # Bind to UDC
    for _ in $(seq 1 10); do
        UDC=$(first_udc) && break
        sleep 0.5
    done

    if [ -n "$UDC" ]; then
        echo "$UDC" >UDC
    else
        return 1
    fi
)

# ==============================================================================
# 7. GADGET SUPERVISOR
# ==============================================================================
HOST_IP="169.254.1.2"
# 6 failures * 5 seconds = 30 second timeout before USB reset
MAX_FAILURES=6
RESET_COUNT_FILE="/tmp/usb_reset_count"

# Owns the whole gadget lifecycle from one background process: load modules,
# (re)create the gadget whenever usb0 is absent, keep the link addressed, and
# rebind the UDC after sustained ping loss. Single owner means no races over
# configfs, and a transient bring-up miss self-heals instead of leaving a
# headless device offline until a power cycle.
start_gadget_supervisor() {
    (
        FAIL_COUNT=0
        while true; do
            # No usb0 yet -> load modules (early-returns once the framework is
            # up), then (re)create and bind the gadget, then recheck.
            if ! ip link show dev "$USB_IFACE" >/dev/null 2>&1; then
                load_usb_modules && setup_gadget
                FAIL_COUNT=0
                sleep 5
                continue
            fi

            ip link set "$USB_IFACE" up 2>/dev/null
            case "$(ip addr show dev "$USB_IFACE" 2>/dev/null)" in
                *169.254.1.1/30*) ;;
                *)
                    ip addr flush dev "$USB_IFACE" 2>/dev/null
                    ip neigh flush dev "$USB_IFACE" 2>/dev/null
                    ip addr add 169.254.1.1/30 dev "$USB_IFACE" 2>/dev/null
                    ;;
            esac

            if ping -c 1 -W 1 "$HOST_IP" >/dev/null 2>&1; then
                FAIL_COUNT=0
            else
                FAIL_COUNT=$((FAIL_COUNT + 1))
            fi

            if [ "$FAIL_COUNT" -ge "$MAX_FAILURES" ]; then
                RESET_COUNT=$(cat "$RESET_COUNT_FILE" 2>/dev/null || echo 0)
                RESET_COUNT=$((RESET_COUNT + 1))
                echo "$RESET_COUNT" >"$RESET_COUNT_FILE"
                # No logger here: the hardened image runs no syslogd.

                echo "" >"$USB_GADGET/UDC" 2>/dev/null
                sleep 1
                UDC=$(first_udc)
                [ -n "$UDC" ] && echo "$UDC" >"$USB_GADGET/UDC" 2>/dev/null
                sleep 2
                FAIL_COUNT=0
            fi

            sleep 5
        done
    ) &
}

# ==============================================================================
# 8. APP SUPERVISOR
# ==============================================================================
#
# NOTE: The signer handles its own first-boot detection and setup.
# This script just mounts partitions, ensures logging, and starts the signer
# as the russignol user.
#
R_CMD="/bin/russignol-signer"
PANIC_LOG="/data/logs/panic.log"

# Signer exits with this code to request a clean reboot from the supervisor
# (used to land each PIN-blob migration step on a fresh boot).
# Must stay in sync with the matching constants in
# `rpi-signer/src/app.rs` (`EXIT_CODE_REBOOT`) and
# `rpi-signer/buildroot-external/rootfs-overlay-dev/etc/init.d/S20russignol`.
EXIT_CODE_REBOOT=42

run_supervisor() {
    cd /home/russignol || return 1

    # Main loop - run signer
    # First boot (no partitions): run as root for storage setup (sfdisk needs root)
    #   - Signer will drop privileges to russignol after storage completes
    #   - No log redirection (partitions don't exist yet, errors show on display)
    # After setup: run as unprivileged russignol user via su with logging
    # Grant russignol write access to CPU freq control (sysfs resets to root each boot)
    chown russignol /sys/devices/system/cpu/cpufreq/policy0/scaling_setspeed 2>/dev/null
    chown russignol /sys/class/leds/ACT/brightness 2>/dev/null

    if ! partition_exists 3 || ! partition_exists 4; then
        # First boot: run as root, no log redirection (would fail anyway)
        $R_CMD
        ec=$?
    else
        # Ensure log directory exists
        mkdir -p "${DATA_MOUNT}/logs"
        # Migration boots run the signer as root, which leaves
        # signer.log (and panic.log) owned root:root. The next normal
        # boot runs the signer as russignol via su; RotatingWriter
        # would then fail to append to a root-owned signer.log.
        # Reclaim ownership unconditionally.
        chown "$R_USER" "${DATA_MOUNT}/logs/"*.log 2>/dev/null

        # Truncate panic log if it exceeds 1MB
        if [ -f "$PANIC_LOG" ] && [ "$(wc -c <"$PANIC_LOG")" -gt 1048576 ]; then
            : >"$PANIC_LOG"
        fi

        # Migration boots run as root so the signer can chown/chmod the
        # promoted v2 canonical and remount /keys ro before demoting
        # to russignol in-process.
        if needs_migration; then
            log_debug "Migration boot - running as root; signer demotes in-process"
            $R_CMD >/dev/null 2>>"$PANIC_LOG"
            ec=$?
        else
            # Binary manages its own log file via RotatingWriter; init only captures panics
            su -s /bin/sh -c "$R_CMD" "$R_USER" >/dev/null 2>>"$PANIC_LOG"
            ec=$?
        fi
    fi

    if [ "$ec" = "$EXIT_CODE_REBOOT" ]; then
        log_debug "Signer requested reboot (exit $ec)"
        reboot -f
    fi

    # Don't restart - error should remain visible on display
    # System halts on panic (panic=0 in cmdline), power cycle to recover
    exit 0
}

# ==============================================================================
# MAIN - Enable functions one by one for debugging
# ==============================================================================

log_debug "=== INIT START ==="

log_debug "Before init_signals"
init_signals
log_debug "After init_signals"

log_debug "Before init_mounts"
init_mounts
log_debug "After init_mounts"

log_debug "Disabling activity LED"
echo 0 >/sys/class/leds/ACT/brightness 2>/dev/null

log_debug "Before init_mdev"
init_mdev
log_debug "After init_mdev"

log_debug "Before init_rng"
init_rng
log_debug "After init_rng"

log_debug "Before init_keys_partition"
init_keys_partition
log_debug "After init_keys_partition"

log_debug "Before init_data_partition"
init_data_partition
log_debug "After init_data_partition"

# Gadget bring-up + watchdog run as one background supervisor (single owner of
# the gadget lifecycle) so the signer's startup is never blocked on USB.
log_debug "Before start_gadget_supervisor"
start_gadget_supervisor
log_debug "After start_gadget_supervisor"

log_debug "Before run_supervisor"
run_supervisor
